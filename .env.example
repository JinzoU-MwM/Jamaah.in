# Environment
APP_ENV=development

# Server
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=50051
PACKAGE_SERVICE_PORT=50052
JAMAAH_SERVICE_PORT=50053
INVOICE_SERVICE_PORT=50054
FINANCE_SERVICE_PORT=50055
AIOCR_SERVICE_PORT=50056

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=jamaah
POSTGRES_PASSWORD=Jamaah123!
POSTGRES_SSLMODE=disable

AUTH_DB_URL=postgres://jamaah:Jamaah123!@localhost:5433/jamaah_auth?sslmode=disable
PACKAGE_DB_URL=postgres://jamaah:Jamaah123!@localhost:5433/jamaah_package?sslmode=disable
JAMAAH_DB_URL=postgres://jamaah:Jamaah123!@localhost:5433/jamaah_crm?sslmode=disable
INVOICE_DB_URL=postgres://jamaah:Jamaah123!@localhost:5433/jamaah_invoice?sslmode=disable
FINANCE_DB_URL=postgres://jamaah:Jamaah123!@localhost:5433/jamaah_finance?sslmode=disable
AIOCR_DB_URL=postgres://jamaah:Jamaah123!@localhost:5433/jamaah_aiocr?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# NATS
NATS_ADDR=nats://localhost:4222

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jamaah-docs
MINIO_USE_SSL=false

# JWT
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Gemini
GEMINI_API_KEY=

# Service addresses (for gateway)
AUTH_SERVICE_ADDR=localhost:50051
PACKAGE_SERVICE_ADDR=localhost:50052
JAMAAH_SERVICE_ADDR=localhost:50053
INVOICE_SERVICE_ADDR=localhost:50054
FINANCE_SERVICE_ADDR=localhost:50055
AIOCR_SERVICE_ADDR=localhost:50056